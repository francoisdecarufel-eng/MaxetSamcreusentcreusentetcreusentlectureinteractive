<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Max et Sam... creusent, creusent et creusent</title>
    
    <!-- Tailwind CSS pour un design rapide, responsive et accessible -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- React & ReactDOM (Versions classiques pour compatibilité standalone) -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    
    <!-- Babel pour la compilation JSX in-browser -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <!-- Configuration Babel Obligatoire -->
    <script>
      Babel.registerPreset('react-classic', {
        presets: [
          [Babel.availablePresets['react'], { runtime: 'classic' }]
        ]
      });
    </script>

    <style>
        /* Styles personnalisés pour l'accessibilité et la gamification */
        body {
            font-family: 'Comic Sans MS', 'Salsa', 'Arial Rounded MT Bold', sans-serif; /* Polices ludiques et lisibles */
            background-color: #fef3c7; /* Fond ambre clair, reposant pour les yeux */
            color: #451a03; /* Contraste élevé */
        }
        .btn-interactive {
            transition: all 0.2s ease-in-out;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }
        .btn-interactive:active {
            transform: scale(0.95);
            box-shadow: none;
        }
        .pop-in {
            animation: popIn 0.3s ease-out forwards;
        }
        @keyframes popIn {
            0% { transform: scale(0.5); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>
</head>
<body class="min-h-screen pb-10">
    <div id="root"></div>

    <script type="text/babel" data-type="module" data-presets="react-classic">
        const { useState, useEffect } = React;


        // Composant d'encadré d'apprentissage
        const LessonBox = ({ title, icon, children }) => (
            <div className="bg-white border-4 border-amber-500 rounded-2xl p-6 mb-8 shadow-lg relative">
                <div className="absolute -top-6 -left-4 bg-amber-500 text-white text-3xl p-3 rounded-full shadow-md">
                    {icon}
                </div>
                <h2 className="text-2xl font-bold text-amber-700 ml-10 mb-4">{title}</h2>
                <div className="text-lg text-stone-700 leading-relaxed">
                    {children}
                </div>
            </div>
        );

        // Composant de rétroaction (Feedback)
        const FeedbackModal = ({ isCorrect, hint, onRetry, onContinue }) => (
            <div className="mt-4 p-5 rounded-xl text-center pop-in shadow-inner border-4 border-solid"
                 style={{ 
                     backgroundColor: isCorrect ? '#dcfce7' : '#fee2e2', 
                     borderColor: isCorrect ? '#22c55e' : '#ef4444' 
                 }}>
                <div className="text-4xl mb-2">{isCorrect ? '🎉' : '🤔'}</div>
                <h3 className={`text-2xl font-bold ${isCorrect ? 'text-green-800' : 'text-red-800'}`}>
                    {isCorrect ? 'Bravo ! C\'est exact !' : 'Oups ! Essaie encore.'}
                </h3>
                {!isCorrect && hint && (
                    <p className="mt-2 text-red-700 bg-red-100 p-3 rounded-lg border-2 border-red-300 inline-block text-lg">💡 <strong>Indice :</strong> {hint}</p>
                )}
                <div className="mt-4 flex justify-center gap-4">
                    {!isCorrect && (
                        <button onClick={onRetry} className="btn-interactive bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-full font-bold text-lg flex items-center gap-2">
                            🔄 Réessayer
                        </button>
                    )}
                    {isCorrect && onContinue && (
                        <button onClick={onContinue} className="btn-interactive bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-full font-bold text-lg flex items-center gap-2 shadow-md">
                            Continuer ➡️
                        </button>
                    )}
                </div>
            </div>
        );


        // ONGLET 1 : Découverte
        const Tab1Discovery = ({ addScore, onNext }) => {
            const [feedback, setFeedback] = useState(null); // null, 'correct', 'incorrect'

            const question = {
                title: "Que font principalement Max et Sam du début à la fin de l'histoire ?",
                options: [
                    { id: 'a', text: "Ils dorment sous un arbre.", correct: false },
                    { id: 'b', text: "Ils creusent pour trouver quelque chose d'extraordinaire.", correct: true },
                    { id: 'c', text: "Ils construisent une maison en bois.", correct: false }
                ],
                hint: "Regarde bien le titre de l'histoire ! L'action y est répétée plusieurs fois."
            };

            const handleAnswer = (isCorrect) => {
                if (isCorrect) {
                    setFeedback('correct');
                    addScore(25);
                } else {
                    setFeedback('incorrect');
                }
            };

            return (
                <div className="animate-fade-in">
                    <LessonBox title="Mission 1 : Découvrir les personnages" icon="🕵️‍♂️">
                        <p>Pour bien comprendre une histoire, tu dois d'abord observer les personnages.</p>
                        <ul className="list-disc ml-6 mt-2">
                            <li><strong>Qui</strong> sont-ils ? (Leur nom)</li>
                            <li><strong>Que font-ils ?</strong> (Leurs actions principales)</li>
                        </ul>
                        <p className="mt-2 bg-blue-50 p-3 rounded-lg border-l-4 border-blue-500">
                            <strong>Exemple :</strong> Si un personnage court tout le temps, on comprend qu'il est pressé ou sportif !
                        </p>
                    </LessonBox>

                    <div className="bg-white p-6 rounded-2xl shadow-md border-2 border-stone-200">
                        <h3 className="text-xl font-bold text-stone-800 mb-6">À toi de jouer ! ⛏️</h3>
                        <p className="text-lg mb-4 font-semibold">{question.title}</p>
                        
                        {!feedback && (
                            <div className="flex flex-col gap-3">
                                {question.options.map(opt => (
                                    <button 
                                        key={opt.id}
                                        onClick={() => handleAnswer(opt.correct)}
                                        className="btn-interactive text-left p-4 rounded-xl border-2 border-amber-200 bg-amber-50 hover:bg-amber-100 hover:border-amber-400 text-lg text-stone-700 transition-colors font-bold"
                                    >
                                        {opt.text}
                                    </button>
                                ))}
                            </div>
                        )}

                        {feedback === 'incorrect' && (
                            <FeedbackModal 
                                isCorrect={false} 
                                hint={question.hint} 
                                onRetry={() => setFeedback(null)} 
                            />
                        )}
                        
                        {feedback === 'correct' && (
                            <FeedbackModal 
                                isCorrect={true} 
                                onContinue={onNext} 
                            />
                        )}
                    </div>
                </div>
            );
        };


        // ONGLET 2 : Forces et faiblesses
        const Tab2Strengths = ({ addScore, onNext }) => {
            const [selectedTrait, setSelectedTrait] = useState(null);
            const [matches, setMatches] = useState({ aime: [], force: [], faiblesse: [] });
            const [feedback, setFeedback] = useState(null);

            const traits = [
                { id: 't1', text: "Explorer et découvrir", correctCategory: 'aime' },
                { id: 't2', text: "Il est très persévérant", correctCategory: 'force' },
                { id: 't3', text: "Il est trop concentré et ne voit pas les diamants autour de lui", correctCategory: 'faiblesse' }
            ];

            const categories = [
                { id: 'aime', title: "Ce qu'il aime ❤️", color: "bg-pink-100 border-pink-500 text-pink-900" },
                { id: 'force', title: "Une de ses forces ⭐", color: "bg-blue-100 border-blue-500 text-blue-900" },
                { id: 'faiblesse', title: "Une de ses faiblesses ⚠️", color: "bg-purple-100 border-purple-500 text-purple-900" }
            ];

            const availableTraits = traits.filter(t => 
                !matches.aime.includes(t.id) && !matches.force.includes(t.id) && !matches.faiblesse.includes(t.id)
            );

            const handleTraitClick = (trait) => {
                setSelectedTrait(trait);
                setFeedback(null);
            };

            const handleCategoryClick = (categoryId) => {
                if (!selectedTrait) return;

                if (selectedTrait.correctCategory === categoryId) {
                    setMatches(prev => ({
                        ...prev,
                        [categoryId]: [...prev[categoryId], selectedTrait.id]
                    }));
                    setSelectedTrait(null);
                    setFeedback({ type: 'success', msg: "Excellent classement !" });
                    addScore(10);
                } else {
                    setFeedback({ type: 'error', msg: "Oups ! Ce n'est pas la bonne catégorie." });
                    setTimeout(() => setFeedback(null), 2500);
                }
            };

            return (
                <div className="animate-fade-in">
                    <LessonBox title="Mission 2 : Dresser le portrait" icon="🎨">
                        <p>Les personnages de livres sont comme nous : ils ont des <strong>forces</strong> (ce qu'ils font bien) et des <strong>faiblesses</strong> (leurs petits défauts ou erreurs).</p>
                        <p className="mt-2 bg-blue-50 p-3 rounded-lg border-l-4 border-blue-500">
                            <strong>Une force :</strong> Être courageux, patient ou <strong>persévérant</strong> (ne pas abandonner).<br/>
                            <strong>Une faiblesse :</strong> Être trop distrait (ne pas remarquer les choses).
                        </p>
                    </LessonBox>

                    <div className="bg-white p-6 rounded-2xl shadow-md border-2 border-stone-200">
                        <h3 className="text-xl font-bold text-stone-800 mb-2">Associe chaque étiquette à la bonne catégorie !</h3>
                        <p className="mb-6 text-stone-600">1. Clique sur une étiquette grise ci-dessous. <br/>2. Clique ensuite sur la zone de catégorie de ton choix.</p>

                        {/* Traits à classer */}
                        <div className="flex flex-wrap gap-3 mb-8 justify-center min-h-[60px]">
                            {availableTraits.map(trait => (
                                <button 
                                    key={trait.id}
                                    onClick={() => handleTraitClick(trait)}
                                    className={`btn-interactive p-4 rounded-xl border-4 font-bold shadow-md transition-all text-lg
                                        ${selectedTrait?.id === trait.id ? 'bg-amber-300 border-amber-600 scale-105' : 'bg-stone-100 border-stone-400 text-stone-800 hover:bg-stone-200'}`}
                                >
                                    {trait.text}
                                </button>
                            ))}
                            {availableTraits.length === 0 && (
                                <div className="text-xl font-bold text-green-800 bg-green-100 p-6 rounded-xl pop-in w-full text-center flex flex-col items-center gap-4 border-4 border-green-500">
                                    <span>🎉 Bravo ! Tu as dressé un portrait parfait !</span>
                                    <button 
                                        onClick={onNext}
                                        className="btn-interactive bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-full font-bold text-lg flex items-center gap-2 shadow-md"
                                    >
                                        Continuer vers la mission 3 ➡️
                                    </button>
                                </div>
                            )}
                        </div>

                        {/* Feedback temporaire */}
                        {feedback && (
                            <div className={`text-center mb-6 p-3 rounded-xl font-bold pop-in border-4 text-lg ${feedback.type === 'error' ? 'bg-red-100 text-red-700 border-red-500 animate-bounce' : 'bg-green-100 text-green-700 border-green-500'}`}>
                                {feedback.msg}
                            </div>
                        )}

                        {/* Catégories (Zones de dépôt) */}
                        <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                            {categories.map(cat => (
                                <div 
                                    key={cat.id}
                                    onClick={() => handleCategoryClick(cat.id)}
                                    className={`border-4 border-solid rounded-2xl p-5 min-h-[180px] cursor-pointer transition-all duration-300 shadow-md ${cat.color} ${selectedTrait ? 'ring-4 ring-offset-2 ring-amber-500 scale-105 border-amber-400' : 'hover:scale-105'}`}
                                >
                                    <h4 className="text-center font-extrabold text-xl mb-4 py-2 bg-white/50 rounded-xl">{cat.title}</h4>
                                    
                                    {selectedTrait && matches[cat.id].length === 0 && (
                                        <div className="text-center font-bold text-amber-900 animate-bounce mt-4 bg-amber-200 p-2 rounded-lg border-2 border-amber-500">
                                            👇 Clique ici
                                        </div>
                                    )}

                                    <div className="flex flex-col gap-3">
                                        {matches[cat.id].map(traitId => {
                                            const trait = traits.find(t => t.id === traitId);
                                            return (
                                                <div key={traitId} className="bg-blue-100 p-3 rounded-xl text-base font-bold shadow-md pop-in text-center border-4 border-solid border-blue-400 text-stone-900">
                                                    {trait.text}
                                                </div>
                                            )
                                        })}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            );
        };


        // ONGLET 3 : Justification (Grammaire intégrée)
        const Tab3Justification = ({ addScore, onNext }) => {
            const [selectedVerb, setSelectedVerb] = useState(false);
            const [selectedAdj, setSelectedAdj] = useState(false);
            const [feedback, setFeedback] = useState(null);

            const handleWordClick = (wordType) => {
                if (wordType === 'verb' && !selectedVerb) {
                    setSelectedVerb(true);
                    addScore(15);
                    setFeedback({msg: "✅ Excellent ! « creusent » est bien le verbe. C'est l'action que font les personnages !", type: 'success'});
                } else if (wordType === 'adj' && !selectedAdj) {
                    setSelectedAdj(true);
                    addScore(15);
                    setFeedback({msg: "✅ Super ! « extraordinaire » est un adjectif. Il décrit comment est la chose qu'ils cherchent.", type: 'success'});
                } else if (wordType === 'wrong') {
                    setFeedback({msg: "❌ Oups, ce n'est pas le bon mot. Cherche l'action (verbe) ou le mot qui décrit (adjectif).", type: 'error'});
                }
                
                setTimeout(() => setFeedback(null), 4000);
            };

            return (
                <div className="animate-fade-in">
                    <LessonBox title="Mission 3 : Trouver les preuves" icon="🔍">
                        <p>Un bon lecteur est comme un détective : il doit <strong>laisser des traces</strong> et <strong>justifier</strong> (prouver) ce qu'il dit avec des indices du texte ou des images.</p>
                        
                        <div className="mt-4 bg-yellow-50 p-4 rounded-xl border-2 border-yellow-400">
                            <h4 className="font-bold text-yellow-800 text-lg mb-2">🧠 Minute Grammaire : Les classes de mots</h4>
                            <ul className="list-disc ml-6 text-yellow-900 space-y-2">
                                <li><strong>Le verbe :</strong> Il exprime l'action du personnage (Ex: Il <em>cherche</em>).</li>
                                <li><strong>L'adjectif :</strong> Il sert à décrire comment est une personne ou une chose (Ex: Un trésor <em>brillant</em>).</li>
                            </ul>
                        </div>
                    </LessonBox>

                    <div className="bg-white p-6 rounded-2xl shadow-md border-2 border-stone-200">
                        <h3 className="text-xl font-bold text-stone-800 mb-4">À toi de jouer : Manipulons la phrase !</h3>
                        <p className="mb-4 text-stone-600">Clique directement sur les mots colorés dans la phrase ci-dessous :</p>
                        
                        <div className="bg-stone-100 p-6 rounded-xl text-center text-2xl leading-loose font-medium mb-6">
                            « Max et Sam{' '}
                            <span 
                                onClick={() => handleWordClick('verb')} 
                                className={`px-2 py-1 rounded cursor-pointer transition-colors border-4 border-solid ${selectedVerb ? 'bg-blue-100 border-blue-500 font-bold text-blue-900' : 'bg-white border-blue-300 shadow hover:bg-blue-50'}`}
                            >
                                creusent
                            </span>
                            {' '}profondément pour trouver quelque chose d'{''}
                            <span 
                                onClick={() => handleWordClick('adj')} 
                                className={`px-2 py-1 rounded cursor-pointer transition-colors border-4 border-solid ${selectedAdj ? 'bg-green-100 border-green-500 font-bold text-green-900' : 'bg-white border-green-300 shadow hover:bg-green-50'}`}
                            >
                                extraordinaire
                            </span>
                            {' '}! »
                        </div>

                        <div className="flex flex-col sm:flex-row justify-center gap-6 mb-6">
                            <div className={`p-4 rounded-xl border-4 text-center transition-all ${selectedVerb ? 'bg-blue-100 border-blue-500' : 'bg-stone-50 border-stone-300'}`}>
                                <p className="font-bold text-lg mb-2">1. Trouve le VERBE</p>
                                <p className="text-sm">Clique sur le mot qui indique l'action principale.</p>
                                {selectedVerb && <div className="mt-2 text-2xl">✅</div>}
                            </div>
                            <div className={`p-4 rounded-xl border-4 text-center transition-all ${selectedAdj ? 'bg-green-100 border-green-500' : 'bg-stone-50 border-stone-300'}`}>
                                <p className="font-bold text-lg mb-2">2. Trouve l'ADJECTIF</p>
                                <p className="text-sm">Clique sur le mot qui décrit ce qu'ils cherchent.</p>
                                {selectedAdj && <div className="mt-2 text-2xl">✅</div>}
                            </div>
                        </div>

                        {feedback && (
                            <div className={`text-center p-3 rounded-xl font-bold pop-in border-4 text-lg ${feedback.type === 'error' ? 'bg-red-100 text-red-700 border-red-500' : 'bg-emerald-100 text-emerald-700 border-emerald-500'}`}>
                                {feedback.msg}
                            </div>
                        )}

                        {selectedVerb && selectedAdj && (
                            <div className="mt-6 bg-amber-100 border-l-8 border-amber-500 p-6 rounded-r-xl pop-in flex flex-col md:flex-row justify-between items-center gap-4 shadow-md">
                                <p className="text-stone-800 text-lg">
                                    <strong>💡 Constat :</strong> Grâce au <strong>verbe</strong>, je sais ce qu'ils font. Grâce à l'<strong>adjectif</strong>, je comprends qu'ils sont motivés par un grand rêve !
                                </p>
                                <button 
                                    onClick={onNext}
                                    className="btn-interactive bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-full font-bold text-lg flex items-center gap-2 shadow-md shrink-0"
                                >
                                    Continuer vers le bilan ➡️
                                </button>
                            </div>
                        )}
                    </div>
                </div>
            );
        };


        // ONGLET 4 : Trace écrite possible
        const Tab4Summary = ({ addScore }) => {
            const [showRepetitionAnswer, setShowRepetitionAnswer] = useState(false);
            const [tableCompleted, setTableCompleted] = useState(false);

            const handleCompleteTable = () => {
                setTableCompleted(true);
                addScore(20);
            };

            return (
                <div className="animate-fade-in">
                    <LessonBox title="Mission 4 : Le secret de l'auteur" icon="✍️">
                        <p>Les auteurs utilisent des techniques (des procédés) pour faire ressentir des émotions ou faire comprendre un message aux lecteurs.</p>
                    </LessonBox>

                    <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
                        {/* Question Répétition */}
                        <div className="bg-white p-6 rounded-2xl shadow-md border-2 border-stone-200">
                            <h3 className="text-xl font-bold text-stone-800 mb-4">L'effet de répétition 🔄</h3>
                            <p className="text-lg mb-4 font-semibold">Pourquoi l'auteur répète-t-il la phrase : <br/><strong>« Max et Sam creusent, creusent, creusent... »</strong> ?</p>
                            
                            {!showRepetitionAnswer ? (
                                <button 
                                    onClick={() => { setShowRepetitionAnswer(true); addScore(10); }}
                                    className="btn-interactive w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-4 px-6 rounded-xl text-lg shadow-md"
                                >
                                    Révéler la réponse
                                </button>
                            ) : (
                                <div className="bg-green-100 border-4 border-green-400 p-4 rounded-xl pop-in text-green-900 shadow-md">
                                    <p className="font-bold text-lg mb-2">💡 La répétition nous montre que :</p>
                                    <ul className="list-disc ml-6 text-base space-y-1">
                                        <li>Ils travaillent pendant <strong>très longtemps</strong>.</li>
                                        <li>Ils sont <strong>persévérants</strong>.</li>
                                        <li>Ils font beaucoup d'<strong>efforts</strong> sans abandonner !</li>
                                    </ul>
                                </div>
                            )}
                        </div>

                        {/* Trace Écrite */}
                        <div className="bg-white p-6 rounded-2xl shadow-md border-2 border-stone-200 flex flex-col justify-between">
                            <div>
                                <h3 className="text-xl font-bold text-stone-800 mb-4">Mon carnet d'enquêteur 📝</h3>
                                <p className="mb-4 text-stone-600">Voici le résumé complet de nos découvertes sur les personnages à imprimer.</p>
                            </div>
                            
                            {!tableCompleted ? (
                                <div className="flex-grow flex items-center justify-center my-6">
                                    <button 
                                        onClick={handleCompleteTable}
                                        className="btn-interactive bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-8 rounded-2xl text-xl animate-pulse shadow-lg"
                                    >
                                        Imprimer la trace écrite dans mon cerveau 🧠
                                    </button>
                                </div>
                            ) : (
                                <div className="overflow-x-auto pop-in mt-4">
                                    <table className="w-full text-left border-collapse border-4 border-solid border-stone-300">
                                        <thead>
                                            <tr className="bg-stone-200 text-stone-800 font-extrabold text-sm border-b-4 border-stone-300">
                                                <th className="p-3 border border-stone-300">Élément</th>
                                                <th className="p-3 border border-stone-300">Ma réponse</th>
                                                <th className="p-3 border border-stone-300">Preuve</th>
                                            </tr>
                                        </thead>
                                        <tbody className="text-sm">
                                            <tr className="bg-white">
                                                <td className="p-3 border border-stone-300 font-bold">Ce qu'il fait</td>
                                                <td className="p-3 border border-stone-300 font-bold">Il creuse pour trouver l'extraordinaire.</td>
                                                <td className="p-3 border border-stone-300 italic text-stone-600">Le texte répète « creusent... »</td>
                                            </tr>
                                            <tr className="bg-stone-50">
                                                <td className="p-3 border border-stone-300 font-bold">Une force</td>
                                                <td className="p-3 border border-stone-300 font-bold">Il est très persévérant.</td>
                                                <td className="p-3 border border-stone-300 italic text-stone-600">Il continue malgré la fatigue.</td>
                                            </tr>
                                            <tr className="bg-white">
                                                <td className="p-3 border border-stone-300 font-bold">Une faiblesse</td>
                                                <td className="p-3 border border-stone-300 font-bold">Il est trop concentré/distrait.</td>
                                                <td className="p-3 border border-stone-300 italic text-stone-600">Dans l'image, il rate les diamants.</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            )}
                        </div>
                    </div>
                </div>
            );
        };


        // --- APPLICATION PRINCIPALE ---
        const App = () => {
            const [activeTab, setActiveTab] = useState(1);
            const [score, setScore] = useState(0);
            const maxScore = 100;

            const tabs = [
                { id: 1, title: "1. Découverte", icon: "👀" },
                { id: 2, title: "2. Forces / Faiblesses", icon: "⚖️" },
                { id: 3, title: "3. Justification", icon: "🔎" },
                { id: 4, title: "4. Bilan", icon: "📝" },
            ];

            const addScore = (points) => {
                setScore(prev => Math.min(prev + points, maxScore));
            };

            const handleNextTab = () => {
                if (activeTab < 4) {
                    setActiveTab(prev => prev + 1);
                }
            };

            return (
                <div className="max-w-5xl mx-auto p-4 sm:p-6 mt-4">
                    
                    {/* Header et Gamification - Entête Bleu Pâle Uni (Sans motifs hachurés) */}
                    <header className="bg-blue-100 rounded-3xl p-6 shadow-xl mb-8 border-b-8 border-solid border-blue-800 relative overflow-hidden">
                        <div className="relative z-10 text-center">
                            <h1 className="text-3xl sm:text-5xl font-extrabold text-blue-950 mb-4">
                                Max et Sam... <br className="sm:hidden"/> creusent, creusent et creusent
                            </h1>
                            <p className="text-xl text-blue-900 font-bold mb-6">Activité interactive : Le portrait des personnages</p>
                            
                            {/* Barre de progression / Score */}
                            <div className="bg-white p-4 rounded-2xl max-w-md mx-auto shadow-md border-4 border-solid border-blue-400 text-blue-950">
                                <div className="flex justify-between items-center mb-2 font-black text-lg">
                                    <span>Niveau d'Explorateur</span>
                                    <span className="text-amber-600 text-2xl">{score} / {maxScore} ⭐</span>
                                </div>
                                <div className="w-full bg-stone-200 rounded-full h-7 border-2 border-solid border-stone-400 overflow-hidden">
                                    <div 
                                        className="bg-gradient-to-r from-amber-400 to-amber-500 h-full transition-all duration-1000 ease-out flex items-center justify-end px-2"
                                        style={{ width: `${score}%` }}
                                    >
                                        {score > 10 && <span className="text-base">💎</span>}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </header>

                    {/* Navigation des Onglets */}
                    <nav className="flex flex-wrap justify-center gap-2 sm:gap-4 mb-8">
                        {tabs.map(tab => (
                            <button
                                key={tab.id}
                                onClick={() => setActiveTab(tab.id)}
                                className={`btn-interactive px-4 py-3 sm:px-6 sm:py-4 rounded-2xl font-bold text-lg sm:text-xl flex items-center gap-2 transition-all border-solid border-4
                                    ${activeTab === tab.id 
                                        ? 'bg-amber-600 text-white shadow-lg scale-105 border-amber-800' 
                                        : 'bg-white text-stone-600 hover:bg-amber-100 border-stone-300'}`}
                            >
                                <span>{tab.icon}</span>
                                <span className="hidden sm:inline">{tab.title}</span>
                                <span className="sm:hidden">{tab.id}</span>
                            </button>
                        ))}
                    </nav>

                    {/* Contenu de l'onglet actif */}
                    <main className="bg-[#fffbeb] p-2 sm:p-8 rounded-3xl min-h-[500px]">
                        {activeTab === 1 && <Tab1Discovery addScore={addScore} onNext={handleNextTab} />}
                        {activeTab === 2 && <Tab2Strengths addScore={addScore} onNext={handleNextTab} />}
                        {activeTab === 3 && <Tab3Justification addScore={addScore} onNext={handleNextTab} />}
                        {activeTab === 4 && <Tab4Summary addScore={addScore} />}
                    </main>

                    {/* Bouton Recommencer Général */}
                    <div className="mt-12 text-center">
                        <button 
                            onClick={() => { setActiveTab(1); setScore(0); window.location.reload(); }}
                            className="text-stone-500 hover:text-stone-800 font-bold underline px-4 py-2 hover:scale-105 transition-all text-lg"
                        >
                            🔄 Recommencer toute l'activité à zéro
                        </button>
                    </div>

                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
